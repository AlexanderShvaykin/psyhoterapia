.container
  .row
    .col.l6.s12
      %h5.white-text= "#{data.main.name} - психотерапевт"
    .col.l3.s12
      %h5.white-text Контакты
      %ul
        %li.white-text= "телефон: #{data.main.tel}"
        %li.white-text= "email: #{data.main.email}"
        %li.white-text= "skype: #{data.main.skype}"

    .col.l3.s12
      %h5.white-text Карта сайта
      %ul
        %li= link_to 'Главная', '/index.html', class: 'white-text'
        %li= link_to 'Обо мне', "/about.html", class: 'white-text'
        %li= link_to 'Практика', "/practice.html", class: 'white-text'

.footer-copyright
